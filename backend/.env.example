RT_API_KEY=
LINEAR_API_KEY=
HABITICA_USER_ID=
HABITICA_API_KEY=
PORT=3001

# Path to Google service account JSON (relative to backend/)
SHEETS_API_JSON=service-account.json
SHEETS_SPREADSHEET_ID=

# Supabase
SUPABASE_ID=ghyeezgcyccwpqhajghp

# Dashboard: Settings → API Keys → Publishable keys (e.g. name "default").
# Use in frontend env (VITE_SUPABASE_*) if the React app talks to Supabase directly.
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Dashboard: Settings → API Keys → Secret keys (e.g. name "default").
SUPABASE_SECRET_KEY=sb_secret_...
