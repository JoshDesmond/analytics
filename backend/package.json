{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migration": "supabase migration new",
    "db:push": "supabase db push",
    "db:types": "supabase gen types typescript --linked > src/supabase/database.types.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "googleapis": "^173.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.12.4",
    "supabase": "^2.102.0",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3"
  }
}
